    private string searchQuery = string.Empty;

    protected override void OnInitialized()
    {
        InitializeServiceSections();
        filteredServiceSections = serviceSections;
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        searchQuery = e.Value?.ToString() ?? string.Empty;
        FilterServices();
    }

    private void FilterServices()
    {
        if (string.IsNullOrEmpty(searchQuery))
        {
            filteredServiceSections = serviceSections;
        }
        else
        {
            filteredServiceSections = serviceSections.Select(section => new ServiceSection
            {
                Name = section.Name,
                Icon = section.Icon,
                Type = section.Type,
                AddButtonText = section.AddButtonText,
                Resources = section.Resources.Where(resource =>
                    resource.Name.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                    resource.Type.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                    resource.Details.Any(detail => detail.Contains(searchQuery, StringComparison.OrdinalIgnoreCase))
                ).ToList()
            }).Where(section => section.Resources.Any()).ToList();
        }
        StateHasChanged();
    }

