@page "/EditSettings"
@using System.Net.Http.Json
@using System.Text
@using Microsoft.JSInterop
@inject HttpClient Http
@inject IJSRuntime JSRuntime

<h3>Edit Settings.csv</h3>

<style>
    .csv-editor {
        margin: 20px 0;
    }
    
    .csv-editor .table {
        background-color: white;
    }
    
    .csv-editor .table th {
        background-color: #f8f9fa;
        font-weight: bold;
        text-align: center;
    }
    
    .csv-editor .form-control {
        border: 1px solid #dee2e6;
        padding: 5px 8px;
        font-size: 14px;
    }
    
    .csv-editor .btn-sm {
        padding: 4px 8px;
        font-size: 12px;
    }
</style>

@if (saveMessage != null)
{
    <div class="alert alert-primary">
        <strong>Status:</strong> @saveMessage
    </div>
}

@if (_isLoading)
{
    <div class="text-center">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p>Loading CSV data...</p>
    </div>
}
else if (csvRows == null)
{
    <div class="alert alert-danger">
        <p>No CSV data loaded. <button class="btn btn-primary" @onclick="LoadDataAsync">Try Loading Again</button></p>
    </div>
}
else
{
    <div class="csv-editor">
        <div class="mb-3">
            <button type="button" class="btn btn-success" onclick="addNewRowJS()">
                ➕ Add New Row
            </button>
            
            <button type="button" class="btn btn-primary" onclick="downloadCsvJS()">
                💾 Download CSV
            </button>
            
            <button type="button" class="btn btn-warning" onclick="saveChangesToServer()">
                💾 Save Changes
            </button>
            
            <button type="button" class="btn btn-info" onclick="forceReloadData()">
                🔄 Force Reload Latest
            </button>
            
            <button type="button" class="btn btn-secondary" onclick="clearBrowserCache()">
                🧹 Clear Cache
            </button>
        </div>
        
        <div class="table-responsive">
            <table class="table table-bordered">
                <thead>
                    <tr>
                @if (csvRows != null && csvRows.Count > 0 && csvRows[0].Count > 0)
                {
                    @foreach (var header in csvRows[0])
                    {
                        <th>@header</th>
                    }
                    <th>Actions</th>
                }
                    </tr>
                </thead>
                <tbody>
                    @if (csvRows != null && csvRows.Count > 1)
                    {
                        @for (int i = 1; i < csvRows.Count; i++)
                        {
                            int rowIndex = i; 
                            <tr>
                                @for (int j = 0; j < csvRows[i].Count; j++)
                                {
                                    int colIndex = j; 
                                    <td>
                                        <input type="text" class="form-control" value="@csvRows[i][j]" 
                                               @onchange="async (e) => await OnCellChangedAsync(rowIndex, colIndex, e.Value?.ToString() ?? string.Empty)" />
                                    </td>
                                }
                                <td>
                                    <button type="button" class="btn btn-danger btn-sm" onclick="deleteRowJS(this)">Delete</button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<!-- JavaScript CSV Editor Functions -->
<script>
// Add new row to table
window.addNewRowJS = function() {
    try {
        const tableBody = document.querySelector('tbody');
        if (!tableBody) {
            showMessage('❌ Table not found', 'danger');
            return;
        }
        
        const headerCells = document.querySelectorAll('thead th').length - 1; 
        const newRow = document.createElement('tr');
        
        for (let i = 0; i < headerCells; i++) {
            const cell = document.createElement('td');
            cell.innerHTML = '<input type="text" class="form-control" value="" placeholder="Enter value">';
            newRow.appendChild(cell);
        }
        
        const actionCell = document.createElement('td');
        actionCell.innerHTML = '<button type="button" class="btn btn-danger btn-sm" onclick="deleteRowJS(this)">Delete</button>';
        newRow.appendChild(actionCell);
        
        tableBody.appendChild(newRow);
        showMessage('✅ New row added successfully!', 'success');
    } catch (error) {
        console.error('Error adding row:', error);
        showMessage('❌ Error adding row: ' + error.message, 'danger');
    }
};

// Delete row
window.deleteRowJS = function(button) {
    try {
        const row = button.closest('tr');
        if (row) {
            row.remove();
            showMessage('✅ Row deleted successfully!', 'success');
        }
    } catch (error) {
        console.error('Error deleting row:', error);
        showMessage('❌ Error deleting row: ' + error.message, 'danger');
    }
};

// Download CSV
window.downloadCsvJS = function() {
    try {
        const csvData = extractTableData();
        
        const blob = new Blob([csvData], { type: 'text/csv;charset=utf-8;' });
        const url = window.URL.createObjectURL(blob);
        const link = document.createElement('a');
        link.href = url;
        link.download = 'settings.csv';
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
        window.URL.revokeObjectURL(url);
        
        showMessage('✅ CSV file downloaded successfully!', 'success');
    } catch (error) {
        console.error('Error downloading CSV:', error);
        showMessage('❌ Download error: ' + error.message, 'danger');
    }
};

// Save changes (downloads file in Blazor WebAssembly)
window.saveChangesToServer = function() {
    try {
        showMessage('💾 Saving changes...', 'info');
        
        const csvData = extractTableData();
        
        const blob = new Blob([csvData], { type: 'text/csv;charset=utf-8;' });
        const url = window.URL.createObjectURL(blob);
        const link = document.createElement('a');
        link.href = url;
        link.download = 'settings.csv';
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
        window.URL.revokeObjectURL(url);
        
        localStorage.setItem('csv-backup-' + new Date().toISOString(), csvData);
        
        showMessage('✅ Changes saved! File downloaded. Replace wwwroot/settings.csv and reload.', 'success');
        
    } catch (error) {
        console.error('Error saving changes:', error);  
        showMessage('❌ Save error: ' + error.message, 'danger');
    }
};

// Extract table data as CSV
function extractTableData() {
    const rows = [];
    
    const headerCells = document.querySelectorAll('thead th');
    const headers = Array.from(headerCells).slice(0, -1).map(th => th.textContent.trim());
    rows.push(headers.join(','));
    
    const dataRows = document.querySelectorAll('tbody tr');
    dataRows.forEach(row => {
        const inputs = row.querySelectorAll('input[type="text"]');
        const values = Array.from(inputs).map(input => {
            let value = (input.value || '').trim();
            if (value.includes(',') || value.includes('"') || value.includes('\n')) {
                value = '"' + value.replace(/"/g, '""') + '"';
            }
            return value;
        });
        rows.push(values.join(','));
    });
    
    return rows.join('\n');
}

// Force reload data with cache busting
window.forceReloadData = function() {
    try {
        showMessage('🔄 Force reloading latest data...', 'info');
        
        // Clear any cached CSV data
        if ('caches' in window) {
            caches.keys().then(names => {
                names.forEach(name => {
                    caches.delete(name);
                });
            });
        }
        
        // Reload the page with cache busting
        const currentUrl = new URL(window.location);
        currentUrl.searchParams.set('_reload', Date.now());
        window.location.href = currentUrl.toString();
        
    } catch (error) {
        console.error('Error force reloading:', error);
        location.reload(true); // Fallback to hard reload
    }
};

// Clear browser cache for CSV files
window.clearBrowserCache = function() {
    try {
        showMessage('🧹 Clearing browser cache...', 'info');
        
        // Clear service worker caches
        if ('caches' in window) {
            caches.keys().then(cacheNames => {
                return Promise.all(
                    cacheNames.map(cacheName => {
                        console.log('Deleting cache:', cacheName);
                        return caches.delete(cacheName);
                    })
                );
            }).then(() => {
                showMessage('✅ Browser cache cleared successfully!', 'success');
            });
        }
        
        // Clear localStorage backups
        const keys = Object.keys(localStorage);
        keys.forEach(key => {
            if (key.startsWith('csv-backup-')) {
                localStorage.removeItem(key);
            }
        });
        
        // Clear sessionStorage
        sessionStorage.clear();
        
        setTimeout(() => {
            showMessage('ℹ️ Click "Force Reload Latest" to get fresh data', 'info');
        }, 2000);
        
    } catch (error) {
        console.error('Error clearing cache:', error);
        showMessage('❌ Cache clear error: ' + error.message, 'danger');
    }
};

// Show status messages
function showMessage(message, type) {
    let messageContainer = document.querySelector('.status-messages');
    if (!messageContainer) {
        messageContainer = document.createElement('div');
        messageContainer.className = 'status-messages';
        const container = document.querySelector('.csv-editor') || document.querySelector('h3');
        if (container) {
            container.parentNode.insertBefore(messageContainer, container.nextSibling);
        }
    }
    
    const messageElement = document.createElement('div');
    messageElement.className = `alert alert-${type} alert-dismissible fade show`;
    messageElement.innerHTML = `
        ${message}
        <button type="button" class="btn-close" onclick="this.parentElement.remove()" aria-label="Close"></button>
    `;
    
    messageContainer.appendChild(messageElement);
    
    setTimeout(() => {
        if (messageElement.parentNode) {
            messageElement.remove();
        }
    }, 8000);
}
</script>

@code {
    List<List<string>>? csvRows;
    string? saveMessage;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try 
        {
            saveMessage = "Loading CSV data...";
            
            csvRows = new List<List<string>>
            {
                new List<string> { "Column1", "Column2", "Column3" },
                new List<string> { "DefaultValue1", "DefaultValue2", "DefaultValue3" }
            };
            
            _isLoading = false;
            await InvokeAsync(StateHasChanged);
            await LoadDataAsync(); 
        }
        catch (Exception ex)
        {
            saveMessage = $"Error loading data: {ex.Message}";
            _isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadDataAsync()
    {
        try
        {
            saveMessage = "Fetching latest CSV file...";
            await InvokeAsync(StateHasChanged);
            
            // Create request with proper cache-busting parameters only
            var cacheBuster = DateTime.Now.Ticks;
            var request = new HttpRequestMessage(HttpMethod.Get, $"settings.csv?v={cacheBuster}");
            
            // Only set valid request headers for cache-busting
            request.Headers.Add("Cache-Control", "no-cache");
            request.Headers.Add("Pragma", "no-cache");
            
            var response = await Http.SendAsync(request);
            
            if (response.IsSuccessStatusCode)
            {
                var csvContent = await response.Content.ReadAsStringAsync();
                csvRows = ParseCsvContent(csvContent);
                saveMessage = $"✅ Latest CSV loaded! ({csvRows.Count - 1} data rows) - {DateTime.Now:HH:mm:ss}";
            }
            else  
            {
                saveMessage = $"❌ Could not load CSV file (Status: {response.StatusCode})";
            }
        }
        catch (Exception ex)
        {
            saveMessage = $"❌ Error loading CSV: {ex.Message}";
        }
        
        await InvokeAsync(StateHasChanged);
    }

    private List<List<string>> ParseCsvContent(string content)
    {
        var rows = new List<List<string>>();
        var lines = content.Split(new[] { "\r\n", "\r", "\n" }, StringSplitOptions.RemoveEmptyEntries);
        
        foreach (var line in lines)
        {
            var columns = new List<string>();
            var cells = line.Split(',');
            
            foreach (var cell in cells)
            {
                var cleanCell = cell.Trim();
                if (cleanCell.StartsWith("\"") && cleanCell.EndsWith("\""))
                {
                    cleanCell = cleanCell.Substring(1, cleanCell.Length - 2);
                    cleanCell = cleanCell.Replace("\"\"", "\"");
                }
                columns.Add(cleanCell);
            }
            
            rows.Add(columns);
        }
        
        return rows;
    }

    private async Task OnCellChangedAsync(int rowIndex, int colIndex, string newValue)
    {
        try
        {
            if (csvRows != null && rowIndex >= 0 && rowIndex < csvRows.Count && 
                colIndex >= 0 && colIndex < csvRows[rowIndex].Count)
            {
                csvRows[rowIndex][colIndex] = newValue ?? string.Empty;
                saveMessage = $"Cell [{rowIndex},{colIndex}] updated";
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            saveMessage = $"Error updating cell: {ex.Message}";
            await InvokeAsync(StateHasChanged);
        }
    }
}
